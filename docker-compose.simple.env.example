# MediaStationGo 可选 .env 示例
#
# 新手不建议使用 .env；请直接改 docker-compose.yml，更直观。
# 这个文件只给进阶用户复用多台机器配置时参考。
#
# 如果你确实要用 .env，下面两个路径必须是宿主机/NAS真实路径。

MEDIASTATION_MEDIA_DIR=/your-nas/media
MEDIASTATION_DOWNLOAD_DIR=/your-nas/downloads

# 可选：固定镜像版本。不写则使用 compose 里的 latest。
# MEDIASTATION_IMAGE_TAG=MediaStationGo-v0.0.32

# 可选：修改访问端口。不写则使用 18080。
MEDIASTATION_HTTP_PORT=18080

TZ=Asia/Shanghai
PUID=1000
PGID=1000
