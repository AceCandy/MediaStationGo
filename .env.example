# MediaStationGo 本地开发环境变量模板
# 用法：cp .env.example .env  然后按需修改；dev.sh 启动时自动读取 .env
# 规则：配置项 a.b.c → 环境变量 MEDIASTATION_A_B_C

# ---------- 应用基本 ----------
# 后端端口；改了要同步改 web/vite.config.ts 的 proxy.target
MEDIASTATION_APP_PORT=6201
# 运行环境：development / production
MEDIASTATION_APP_ENV=development
# 调试模式
MEDIASTATION_APP_DEBUG=true
# 数据目录：JWT 密钥、SQLite 主库等（默认 ./data，已 gitignore）
MEDIASTATION_APP_DATA_DIR=./data
# 外部访问地址，留空即可（反代/对外暴露时再填）
# MEDIASTATION_APP_SERVER_URL=http://127.0.0.1:6201

# ---------- 日志 ----------
# info / debug / warn / error（本地开发建议 info 或 debug）
MEDIASTATION_LOGGING_LEVEL=info

# ---------- 数据库 ----------
# 不设 DSN 时自动使用 SQLite；填 DSN 则切到 PostgreSQL
MEDIASTATION_DATABASE_TYPE=auto
# SQLite 文件路径（type=auto 且无 DSN 时生效）
MEDIASTATION_DATABASE_DB_PATH=./data/mediastation.db
# PostgreSQL（需要时取消注释）
# MEDIASTATION_DATABASE_DSN=postgres://mediastation:mediastation@localhost:5432/mediastation?sslmode=disable

# ---------- 刮削 / 识别密钥（按需填写，留空则对应功能不可用）----------
# MEDIASTATION_SECRETS_TMDB_API_KEY=
# MEDIASTATION_SECRETS_TMDB_API_PROXY=
# MEDIASTATION_SECRETS_TMDB_IMAGE_PROXY=
# MEDIASTATION_SECRETS_BANGUMI_ACCESS_TOKEN=
# MEDIASTATION_SECRETS_THETVDB_API_KEY=
# MEDIASTATION_SECRETS_FANART_TV_API_KEY=
# MEDIASTATION_SECRETS_DOUBAN_COOKIE=

# ---------- 可选增强组件（默认关闭，需要时取消注释）----------
# Redis 热缓存
# MEDIASTATION_CACHE_REDIS_URL=redis://localhost:6379/0
# OpenSearch 全文搜索
# MEDIASTATION_SEARCH_BACKEND=opensearch
# MEDIASTATION_SEARCH_OPENSEARCH_URL=http://localhost:9200
